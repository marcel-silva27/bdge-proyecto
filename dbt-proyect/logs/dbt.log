  create view "supermarket"."public"."int_sales_enriched__dbt_tmp"
    
    
  as (
    /*
    int_sales_enriched.sql — Capa Intermedia
    ──────────────────────────────────────────
    Beam serializa status_history como repr() de Python:
      "[{'status': 'CREATED', 'date': datetime.datetime(2026,6,20,18,0,tzinfo=<UTC>)}\n {...}]"

    Esta CTE lo convierte a JSON válido en 4 pasos:
      1. Reemplaza datetime.datetime(...) por string ISO 8601
      2. Agrega coma entre objetos separados por \n
      3. Reemplaza comillas simples por dobles
      4. Castea a JSONB
*/

WITH base AS (
    SELECT * FROM "supermarket"."public"."stg_sales"
),

cleaned AS (
    SELECT
        transaction_id,
        store_id,
        raw_amount,
        currency,
        processed_at,
        batch_id,
        (
            -- Paso 3: comillas simples → dobles
            replace(
                -- Paso 2: "}\n {" → "}, {" (objetos sin coma)
                replace(
                    -- Paso 1: datetime.datetime(Y,M,D,H,Mi,...tzinfo=<UTC>) → "Y-MM-DDTHH:MI:00Z"
                    regexp_replace(
                        status_history::text,
                        'datetime\.datetime\((\d+),\s*(\d+),\s*(\d+),\s*(\d+),\s*(\d+)[^)]*\)',
                        'to_replace_date_\1-\2-\3T\4:\5:00Z',
                        'g'
                    ),
                    E'}\n {',
                    '}, {'
                ),
                '''',
                '"'
            )
        -- Paso 4: limpia el prefijo temporal y castea
        )::text AS sh_text
    FROM base
),

-- Reemplaza el prefijo to_replace_date_ por nada (queda la fecha entre comillas dobles)
fixed AS (
    SELECT
        transaction_id,
        store_id,
        raw_amount,
        currency,
        processed_at,
        batch_id,
        replace(sh_text, '"to_replace_date_', '"')::jsonb AS status_history_json
    FROM cleaned
),

created_events AS (
    SELECT
        transaction_id,
        MIN((event->>'date')::timestamp) AS created_at
    FROM fixed,
         jsonb_array_elements(status_history_json) AS event
    WHERE event->>'status' = 'CREATED'
    GROUP BY transaction_id
),

completed_events AS (
    SELECT
        transaction_id,
        MIN((event->>'date')::timestamp) AS completed_at
    FROM fixed,
         jsonb_array_elements(status_history_json) AS event
    WHERE event->>'status' = 'COMPLETED'
    GROUP BY transaction_id
),

refunded_events AS (
    SELECT DISTINCT
        transaction_id,
        TRUE AS is_refunded
    FROM fixed,
         jsonb_array_elements(status_history_json) AS event
    WHERE event->>'status' = 'REFUNDED'
)

SELECT
    b.transaction_id,
    b.store_id,
    b.raw_amount,
    b.currency,
    b.processed_at,
    b.batch_id,
    cr.created_at,
    co.completed_at,
    ROUND(
        EXTRACT(EPOCH FROM (co.completed_at - cr.created_at)) / 3600.0,
        2
    )                                AS conversion_time_hours,
    COALESCE(re.is_refunded, FALSE)  AS is_refunded

FROM fixed b
LEFT JOIN created_events   cr ON b.transaction_id = cr.transaction_id
LEFT JOIN completed_events co ON b.transaction_id = co.transaction_id
LEFT JOIN refunded_events  re ON b.transaction_id = re.transaction_id
  );
